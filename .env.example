# Copie para .env e preencha. NUNCA comitar .env.

# --- LLM da classificação ---
# Opção A (recomendada): API compatível-OpenAI (DeepSeek / OpenCode Zen / OpenRouter).
# Se preenchidos, têm prioridade sobre o Gemini.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash    # ou deepseek-v4-pro (mais preciso)

# Opção B (fallback): Google AI Studio (Gemini) — usado se LLM_BASE_URL vazio
GEMINI_API_KEY=

# Google Sheets
GOOGLE_SHEETS_ID=
# Caminho do JSON da service account (Google Cloud > IAM > Service Accounts)
GOOGLE_SA_JSON=credentials/service_account.json
# Nome da aba (worksheet) onde grava os prospects
SHEETS_WORKSHEET=prospects

# TRF4
TRF4_HEADLESS=false
